#include <iostream> //Biblioteca de comandos de entrada e saída de dados C++
using namespace std; //Você faz isso para não precisar colocar std:: antes do cout
/*std:: cin>>
std:: cout<<
*/
int main () {
int numero; //Armazena inteiros
cout<<"Digite um inteiro: "; //Mostra o conteúdo do cout na tela, se precisar de outro comando utilizar '<<' após assim como na linha 10 e 11
cin>>numero; //Cadastra uma informação na variável desejada
cout<<numero-1<<"\n"; //endL pula a linha
cout<<numero<<"\n"; //"/n" também pula linha
cout<<numero+1;
return 0; //ou exit(0);
}
