#include <iostream>
using namespace std;

int main()
{
    float altChico, altZe;
    int anos;
    anos = 0;
    altChico = 1.50;
    altZe = 1.10;
    
    while(altZe<=altChico){
        anos++;
        altZe += 0.03;
        altChico += 0.02;
        cout<<"A altura de Zé é de "<<altZe<<" e a de Chico "<<altChico<<" em "<<anos<<" anos."<<endl;
    }
    return 0;
}
