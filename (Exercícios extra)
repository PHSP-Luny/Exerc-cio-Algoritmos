#include <iostream>
using namespace std;

int main()
{
    float salario, total;
    int cont;
    cont = 0;
    total = 0;
    
    while(cont<10){
        cout<<"Informe o salário: ";
        cin>>salario;
        total = total+salario;
        cont++;
    }
    cout<<total;
    return 0;
}
